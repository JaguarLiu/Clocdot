{
  "name": "clocdot",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"yarn workspace @clocdot/client dev\" \"yarn workspace @clocdot/server dev\"",
    "build": "yarn workspace @clocdot/client build",
    "dev:client": "yarn workspace @clocdot/client dev",
    "dev:server": "yarn workspace @clocdot/server dev",
    "db:migrate": "yarn workspace @clocdot/server db:migrate",
    "db:push": "yarn workspace @clocdot/server db:push",
    "db:studio": "yarn workspace @clocdot/server db:studio"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
